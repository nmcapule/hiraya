{
  "name": "hiraya-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "app": "bun packages/app-cli/src/cli.ts",
    "app:example": "bun run --cwd examples/hello-app build && bun run app package examples/hello-app/dist examples/hello-app.hiraya.app",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "bun test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hiraya/apps-contracts": "workspace:*",
    "@hiraya/app-cli": "workspace:*",
    "@hiraya/app-runtime": "workspace:*",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@noble/hashes": "^2.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "codemirror": "^6.0.2",
    "fflate": "^0.8.3",
    "prettier": "^3.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
